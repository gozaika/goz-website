{
  "name": "@gozaika/monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env.local -- npm --workspace @gozaika/website run dev",
    "dev:website": "dotenv -e .env.local -- npm --workspace @gozaika/website run dev",
    "dev:consumer": "dotenv -e .env.local -- npm --workspace @gozaika/consumer-web run dev",
    "dev:restaurant": "dotenv -e .env.local -- npm --workspace @gozaika/restaurant-mgmt-web run dev",
    "dev:admin": "dotenv -e .env.local -- npm --workspace @gozaika/admin-web run dev",
    "build": "dotenv -e .env.local -- npm run build --workspaces --if-present",
    "start": "dotenv -e .env.local -- npm --workspace @gozaika/website run start",
    "lint": "dotenv -e .env.local -- npm run lint --workspaces --if-present",
    "typecheck": "dotenv -e .env.local -- npm run typecheck --workspaces --if-present",
    "test": "dotenv -e .env.local -- npm run test --workspaces --if-present",
    "test:e2e": "dotenv -e .env.local -- npm --workspace @gozaika/website run e2e",
    "test:a11y": "dotenv -e .env.local -- npm --workspace @gozaika/website run a11y",
    "test:lighthouse": "dotenv -e .env.local -- npm --workspace @gozaika/website run lhci",
    "db:seed:demo": "npm run db:seed:demo:slice1 && npm run db:seed:demo:slice2",
    "db:seed:demo:slice1": "dotenv -e .env.local -- tsx scripts/demo/create-demo-auth-users.ts",
    "db:seed:demo:slice2": "dotenv -e .env.local -- tsx scripts/demo/seed-restaurant-onboarding.ts",
    "db:demo:delete": "dotenv -e .env.local -- tsx scripts/demo/delete-demo-sql-data.ts",
    "demo:auth:create": "dotenv -e .env.local -- tsx scripts/demo/create-demo-auth-users.ts",
    "demo:admin:create": "dotenv -e .env.local -- tsx scripts/demo/create-demo-admin-user.ts",
    "demo:auth:delete": "dotenv -e .env.local -- tsx scripts/demo/delete-demo-auth-users.ts",
    "demo:reset": "npm run demo:auth:delete && npm run demo:auth:create && npm run demo:admin:create && npm run db:seed:demo:slice2",
    "ci": "dotenv -e .env.local -- npm run lint --workspaces --if-present && dotenv -e .env.local -- npm run typecheck --workspaces --if-present && dotenv -e .env.local -- npm run test --workspaces --if-present && dotenv -e .env.local -- npm run build --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "supabase": "^2.95.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
