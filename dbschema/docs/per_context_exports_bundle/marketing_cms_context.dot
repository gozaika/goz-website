digraph G {
  graph [layout=dot, rankdir=LR, splines=true, overlap=false, ranksep=1.05, nodesep=0.5, pad=0.3, bgcolor="white", labelloc="t", labeljust="l", fontname="Helvetica", fontsize=20, label="Marketing Cms Context"];
  node [shape=plain, fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];
  subgraph cluster_main_1 {
    label="MARKETING / CMS"; style="rounded,filled"; color="#facc15"; fillcolor="#fefce8"; penwidth=1.5;
    "cms_banner" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>cms_banner</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">banner_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">banner_title</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">placement_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_active</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">banner_body_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">ends_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">starts_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">target_url</FONT></TD></TR></TABLE>>];
    "cms_city_page" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>cms_city_page</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">city_page_title</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_published</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">published_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">body_markdown</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">hero_text</FONT></TD></TR></TABLE>>];
    "cms_page" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>cms_page</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">page_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">page_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">page_title</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">published_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">body_markdown</FONT></TD></TR></TABLE>>];
    "cms_post" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>cms_post</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">post_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">post_slug</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">post_title</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">published_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">body_markdown</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">excerpt_text</FONT></TD></TR></TABLE>>];
    "cms_restaurant_feature" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>cms_restaurant_feature</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">feature_title</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_published</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">published_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">feature_body_markdown</FONT></TD></TR></TABLE>>];
    "cms_seo_metadata" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>cms_seo_metadata</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">entity_type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">seo_title</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">canonical_url</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a78bfa">entity_pk</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">seo_description</FONT></TD></TR></TABLE>>];
    "marketing_partner_lead" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>marketing_partner_lead</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">qualification_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">contact_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">source_campaign_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">source_page_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">consent_captured_flag</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">city_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">cuisine_text</FONT></TD></TR></TABLE>>];
    "marketing_waitlist_lead" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>marketing_waitlist_lead</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">lead_type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">full_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">source_campaign_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">source_page_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">consent_captured_flag</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">city_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">email_address</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">notes</FONT></TD></TR></TABLE>>];
    "notification_delivery_attempt" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>notification_delivery_attempt</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">attempt_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">attempt_number</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">error_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">provider_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">attempted_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">error_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">provider_message_ref</FONT></TD></TR></TABLE>>];
    "notification_device" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>notification_device</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">device_platform_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_active</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">device_label</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">last_seen_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">push_token</FONT></TD></TR></TABLE>>];
    "notification_outbox" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>notification_outbox</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">business_context_type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">send_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">channel_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">scheduled_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">resolved_destination_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">sent_at</FONT></TD></TR></TABLE>>];
    "notification_template" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>notification_template</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">channel_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">locale_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">template_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_active</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">body_template</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">provider_template_ref</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">subject_template</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_1 {
    label="External refs · AUTH / IAM"; style="rounded,dashed"; color="#818cf8"; fillcolor="#ffffff"; penwidth=1.0;
    "iam_profile" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#eef2ff" BORDER="1" COLOR="#818cf8"><B>iam_profile</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">display_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_consumer</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_platform_user</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_restaurant_user</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">email_address</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">phone_e164</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">last_seen_at</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_2 {
    label="External refs · CONSUMER"; style="rounded,dashed"; color="#a78bfa"; fillcolor="#ffffff"; penwidth=1.0;
    "consumer_profile" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f5f3ff" BORDER="1" COLOR="#a78bfa"><B>consumer_profile</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">preferred_language_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">first_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">last_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">marketing_source_code</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_3 {
    label="External refs · DROP / CATALOG"; style="rounded,dashed"; color="#38bdf8"; fillcolor="#ffffff"; penwidth=1.0;
    "storage_object" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f0f9ff" BORDER="1" COLOR="#38bdf8"><B>storage_object</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">bucket_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">mime_type</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">checksum_sha256_hex</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">object_path</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">original_filename</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">size_bytes</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_4 {
    label="External refs · GEO"; style="rounded,dashed"; color="#2dd4bf"; fillcolor="#ffffff"; penwidth=1.0;
    "geo_city" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f0fdfa" BORDER="1" COLOR="#2dd4bf"><B>geo_city</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">city_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">city_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">country_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">currency_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">state_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">timezone_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_active</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_5 {
    label="External refs · RESTAURANT"; style="rounded,dashed"; color="#fb923c"; fillcolor="#ffffff"; penwidth=1.0;
    "restaurant_restaurant" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff7ed" BORDER="1" COLOR="#fb923c"><B>restaurant_restaurant</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">legal_entity_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_slug</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">primary_contact_email</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">primary_contact_phone_e164</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">pickup_instructions</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_6 {
    label="External refs · SUPPORT / INCIDENT"; style="rounded,dashed"; color="#fb7185"; fillcolor="#ffffff"; penwidth=1.0;
    "support_ticket" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff1f2" BORDER="1" COLOR="#fb7185"><B>support_ticket</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">sla_due_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">requester_idempotency_key</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">resolved_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">subject_text</FONT></TD></TR></TABLE>>];
  }
  "geo_city" -> "iam_profile" [label="[S] optional · default_city_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "geo_city" -> "marketing_waitlist_lead" [label="[S] optional · geo_city_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "geo_city" -> "marketing_partner_lead" [label="[S] optional · geo_city_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "marketing_partner_lead" [label="[S] optional · assigned_to_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "consumer_profile" [label="[C] owns · iam_profile_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "geo_city" -> "restaurant_restaurant" [label="[R] has · geo_city_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "iam_profile" -> "restaurant_restaurant" [label="[S] optional · owner_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "storage_object" [label="[S] optional · uploaded_by_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "notification_template" -> "notification_outbox" [label="[S] optional · notification_template_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "notification_outbox" [label="[S] optional · recipient_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "notification_outbox" -> "notification_delivery_attempt" [label="[C] owns · notification_outbox_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "iam_profile" -> "notification_device" [label="[C] owns · iam_profile_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "iam_profile" -> "support_ticket" [label="[S] optional · requester_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "support_ticket" [label="[S] optional · restaurant_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "marketing_partner_lead" -> "support_ticket" [label="[S] optional · marketing_partner_lead_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "support_ticket" [label="[S] optional · assigned_to_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "cms_page" [label="[S] optional · created_by_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "geo_city" -> "cms_city_page" [label="[C] owns · geo_city_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "iam_profile" -> "cms_post" [label="[S] optional · author_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "cms_restaurant_feature" [label="[C] owns · restaurant_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "storage_object" -> "cms_seo_metadata" [label="[S] optional · og_image_storage_object_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "consumer_profile" -> "marketing_waitlist_lead" [label="[S] optional · converted_consumer_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "marketing_partner_lead" [label="[S] optional · converted_restaurant_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "support_ticket" -> "marketing_partner_lead" [label="[S] optional · converted_support_ticket_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  legend_marketing_cms_context [shape=plain, label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
<TR><TD><B>Legend</B></TD></TR>
<TR><TD ALIGN="LEFT">[C] Cascade — red solid 3pt</TD></TR>
<TR><TD ALIGN="LEFT">[R] Restrict — indigo solid 2pt</TD></TR>
<TR><TD ALIGN="LEFT">[S] Set Null — gray dashed 1.5pt</TD></TR>
<TR><TD ALIGN="LEFT">Text colors → violet uuid, blue string, green integer, orange boolean, brown datetime, gold money, cyan json</TD></TR>
</TABLE>>];
}