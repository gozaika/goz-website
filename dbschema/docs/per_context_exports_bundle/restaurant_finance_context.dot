digraph G {
  graph [layout=dot, rankdir=LR, splines=true, overlap=false, ranksep=1.05, nodesep=0.5, pad=0.3, bgcolor="white", labelloc="t", labeljust="l", fontname="Helvetica", fontsize=20, label="Restaurant Finance Context"];
