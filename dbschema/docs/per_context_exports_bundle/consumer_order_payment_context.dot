    "consumer_passport_stat" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f5f3ff" BORDER="1" COLOR="#a78bfa"><B>consumer_passport_stat</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">total_neighborhoods_visited</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">current_tier_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">total_bags_collected</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">total_restaurants_visited</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">last_calculated_at</FONT></TD></TR></TABLE>>];
