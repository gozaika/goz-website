digraph G {
  graph [layout=dot, rankdir=LR, splines=true, overlap=false, ranksep=1.05, nodesep=0.5, pad=0.3, bgcolor="white", labelloc="t", labeljust="l", fontname="Helvetica", fontsize=20, label="Consumer Order Payment Context"];
  node [shape=plain, fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];
  subgraph cluster_main_1 {
    label="CONSUMER"; style="rounded,filled"; color="#a78bfa"; fillcolor="#f5f3ff"; penwidth=1.5;
