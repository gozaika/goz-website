digraph G {
  graph [layout=dot, rankdir=LR, splines=true, overlap=false, ranksep=1.05, nodesep=0.5, pad=0.3, bgcolor="white", labelloc="t", labeljust="l", fontname="Helvetica", fontsize=20, label="Support Incident Context"];
  node [shape=plain, fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];
  subgraph cluster_main_1 {
    label="SUPPORT / INCIDENT"; style="rounded,filled"; color="#fb7185"; fillcolor="#fff1f2"; penwidth=1.5;
    "incident_event" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff1f2" BORDER="1" COLOR="#fb7185"><B>incident_event</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">event_type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">comment_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">recorded_at</FONT></TD></TR></TABLE>>];
    "incident_incident" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff1f2" BORDER="1" COLOR="#fb7185"><B>incident_incident</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">occurred_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">resolved_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">title_text</FONT></TD></TR></TABLE>>];
    "support_ticket" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff1f2" BORDER="1" COLOR="#fb7185"><B>support_ticket</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">sla_due_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">requester_idempotency_key</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">resolved_at</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">subject_text</FONT></TD></TR></TABLE>>];
    "support_ticket_event" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff1f2" BORDER="1" COLOR="#fb7185"><B>support_ticket_event</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">event_type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_internal_note</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">comment_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">recorded_at</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_1 {
    label="External refs · AUTH / IAM"; style="rounded,dashed"; color="#818cf8"; fillcolor="#ffffff"; penwidth=1.0;
    "iam_profile" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#eef2ff" BORDER="1" COLOR="#818cf8"><B>iam_profile</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">display_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_consumer</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_platform_user</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_restaurant_user</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">email_address</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">phone_e164</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#a16207">last_seen_at</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_2 {
    label="External refs · MARKETING / CMS"; style="rounded,dashed"; color="#facc15"; fillcolor="#ffffff"; penwidth=1.0;
    "marketing_partner_lead" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fefce8" BORDER="1" COLOR="#facc15"><B>marketing_partner_lead</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">qualification_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">contact_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">source_campaign_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">source_page_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">consent_captured_flag</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">city_text</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">cuisine_text</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_3 {
    label="External refs · ORDER / PAYMENT"; style="rounded,dashed"; color="#e879f9"; fillcolor="#ffffff"; penwidth=1.0;
    "order_order" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fdf4ff" BORDER="1" COLOR="#e879f9"><B>order_order</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">order_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">payment_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">currency_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">order_number</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">discount_paise</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">subtotal_paise</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">tax_paise</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#facc15">total_paise</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_4 {
    label="External refs · RESTAURANT"; style="rounded,dashed"; color="#fb923c"; fillcolor="#ffffff"; penwidth=1.0;
    "restaurant_restaurant" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#fff7ed" BORDER="1" COLOR="#fb923c"><B>restaurant_restaurant</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">legal_entity_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">restaurant_slug</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">primary_contact_email</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">primary_contact_phone_e164</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">pickup_instructions</FONT></TD></TR></TABLE>>];
  }
  subgraph cluster_ext_5 {
    label="External refs · SHARED / OPS"; style="rounded,dashed"; color="#9ca3af"; fillcolor="#ffffff"; penwidth=1.0;
    "master_incident_severity" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f3f4f6" BORDER="1" COLOR="#9ca3af"><B>master_incident_severity</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">severity_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">severity_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">sort_order</FONT></TD></TR></TABLE>>];
    "master_incident_status" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f3f4f6" BORDER="1" COLOR="#9ca3af"><B>master_incident_status</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">status_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_terminal</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">sort_order</FONT></TD></TR></TABLE>>];
    "master_incident_type" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f3f4f6" BORDER="1" COLOR="#9ca3af"><B>master_incident_type</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">type_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_active</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description</FONT></TD></TR></TABLE>>];
    "master_support_ticket_priority" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f3f4f6" BORDER="1" COLOR="#9ca3af"><B>master_support_ticket_priority</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">priority_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">priority_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">sla_first_response_minutes</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">sort_order</FONT></TD></TR></TABLE>>];
    "master_support_ticket_status" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f3f4f6" BORDER="1" COLOR="#9ca3af"><B>master_support_ticket_status</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">status_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">status_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_terminal</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#4ade80">sort_order</FONT></TD></TR></TABLE>>];
    "master_support_ticket_type" [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2"><TR><TD BGCOLOR="#f3f4f6" BORDER="1" COLOR="#9ca3af"><B>master_support_ticket_type</B></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">type_code</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">type_name</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#fb923c">is_active</FONT></TD></TR><TR><TD ALIGN="LEFT" BORDER="0"><FONT COLOR="#38bdf8">description</FONT></TD></TR></TABLE>>];
  }
  "iam_profile" -> "marketing_partner_lead" [label="[S] optional · assigned_to_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "restaurant_restaurant" [label="[S] optional · owner_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "order_order" [label="[R] has · restaurant_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "iam_profile" -> "support_ticket" [label="[S] optional · requester_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "support_ticket" [label="[S] optional · restaurant_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "order_order" -> "support_ticket" [label="[S] optional · order_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "marketing_partner_lead" -> "support_ticket" [label="[S] optional · marketing_partner_lead_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "master_support_ticket_type" -> "support_ticket" [label="[R] has · master_support_ticket_type_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "master_support_ticket_status" -> "support_ticket" [label="[R] has · master_support_ticket_status_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "master_support_ticket_priority" -> "support_ticket" [label="[R] has · master_support_ticket_priority_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "iam_profile" -> "support_ticket" [label="[S] optional · assigned_to_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "support_ticket" -> "support_ticket_event" [label="[C] owns · support_ticket_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "master_support_ticket_status" -> "support_ticket_event" [label="[S] optional · from_status_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "master_support_ticket_status" -> "support_ticket_event" [label="[S] optional · to_status_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "support_ticket_event" [label="[S] optional · actor_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "incident_incident" [label="[S] optional · restaurant_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "order_order" -> "incident_incident" [label="[S] optional · order_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "support_ticket" -> "incident_incident" [label="[S] optional · support_ticket_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "master_incident_type" -> "incident_incident" [label="[R] has · master_incident_type_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "master_incident_status" -> "incident_incident" [label="[R] has · master_incident_status_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "master_incident_severity" -> "incident_incident" [label="[R] has · master_incident_severity_fk", color="#818cf8", fontcolor="#818cf8", penwidth=2, style="solid"];
  "iam_profile" -> "incident_incident" [label="[S] optional · assigned_to_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "incident_incident" [label="[S] optional · reported_by_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "incident_incident" -> "incident_event" [label="[C] owns · incident_fk", color="#f87171", fontcolor="#f87171", penwidth=3, style="solid"];
  "master_incident_status" -> "incident_event" [label="[S] optional · from_status_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "master_incident_status" -> "incident_event" [label="[S] optional · to_status_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "iam_profile" -> "incident_event" [label="[S] optional · actor_profile_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "restaurant_restaurant" -> "marketing_partner_lead" [label="[S] optional · converted_restaurant_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  "support_ticket" -> "marketing_partner_lead" [label="[S] optional · converted_support_ticket_fk", color="#9ca3af", fontcolor="#9ca3af", penwidth=1.5, style="dashed"];
  legend_support_incident_context [shape=plain, label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
<TR><TD><B>Legend</B></TD></TR>
<TR><TD ALIGN="LEFT">[C] Cascade — red solid 3pt</TD></TR>
<TR><TD ALIGN="LEFT">[R] Restrict — indigo solid 2pt</TD></TR>
<TR><TD ALIGN="LEFT">[S] Set Null — gray dashed 1.5pt</TD></TR>
<TR><TD ALIGN="LEFT">Text colors → violet uuid, blue string, green integer, orange boolean, brown datetime, gold money, cyan json</TD></TR>
</TABLE>>];
}